{
  "expo": {
    "name": "VitaNova AI",
    "slug": "VitaNova",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "vitanova",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f1f2ec"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vitanova.ai"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f1f2ec"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.vitanova.ai"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "VitaNova AI needs camera access to scan food items"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "VitaNova AI needs photo access to analyze food images"
        }
      ],
      "expo-font"
    ]
  }
}
